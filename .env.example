# ─────────────────────────────────────────────
#  Lumiere — Environment Variables Template
#  Copy to .env and fill in your real values.
#  This file IS safe to commit — no real secrets.
# ─────────────────────────────────────────────

# ── PostgreSQL / Database ──────────────────────
DATABASE_URL=postgresql://postgres:<password>@localhost:5432/clinical_db

# ── AI / LLM API Keys ─────────────────────────
# Groq — https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── FastAPI Backend ────────────────────────────
API_PORT=8000

# ── Node.js / Express Backend ─────────────────
PORT=3001

# ── Debug ─────────────────────────────────────
DEBUG=false
